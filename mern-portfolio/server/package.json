{
  "name": "mern-portfolio-server",
  "version": "1.0.0",
  "type": "module",
  "description": "Backend API for MERN Portfolio",
  "main": "src/server.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development node --watch src/server.js",
    "start": "node src/server.js",
    "build": "echo 'No build required for Node.js'",
    "test": "jest --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.js\""
  },
  "keywords": [
    "mern",
    "portfolio",
    "api",
    "express",
    "mongodb"
  ],
  "author": "Riyank",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^8.0.0",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.0.0",
    "express-validator": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "multer": "^1.4.5-lts.1",
    "cloudinary": "^1.40.0",
    "nodemailer": "^6.9.7",
    "redis": "^4.6.12",
    "socket.io": "^4.7.2",
    "axios": "^1.6.2",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "@babel/preset-env": "^7.23.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
